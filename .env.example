# Mode: live (ingest TxLINE) | replay (replay a recorded match)
KEEPER_MODE=replay
REPLAY_FILE=data/sample-match.jsonl
REPLAY_SPEED=10
REPLAY_LOOP=true

# Server
PORT=8787

# TxLINE
TXLINE_NETWORK=devnet            # devnet | mainnet
# TXLINE_BASE_URL=                # optional override

# Solana (devnet). Base58-encoded secret key. NEVER commit the real value.
SOLANA_SECRET_KEY=
SOLANA_RPC_URL=https://api.devnet.solana.com
ANCHOR_INTERVAL_SEC=30
ANCHOR_ENABLED=true

# Engine parameters (defaults live in src/config.ts; override here)
# GAMMA=0.5
# DELTA_MIN=0.008
# DELTA_MAX=0.06
# K_VOL=1.5
# EWMA_HALF_LIFE_SEC=120
# FREEZE_GOAL_SEC=45
# FREEZE_VAR_SEC=90
# CLIP_SIZE=1
# INVENTORY_CAP=10
# MAX_DRAWDOWN=8
# STALE_FEED_SEC=20
