{
  "name": "keeper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous in-play market maker for World Cup outcomes, powered by TxLINE",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"web/src/**/*.{ts,tsx}\"",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.7",
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.3",
    "@solana/web3.js": "^1.95.8",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "pino": "^9.5.0",
    "tsx": "^4.19.2",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.112.0"
  },
  "engines": {
    "node": ">=20"
  }
}
